  "info": {
    "title": "Gustam Platform API",
    "description": "Central API for Gustam Platform",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "admin@gustam.dev"
          },
          "password": {
            "type": "string",
            "example": "password123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Gustam"
          },
          "email": {
            "type": "string",
            "example": "admin@gustam.dev"
          },
          "password": {
            "type": "string",
            "example": "password123"
          },
          "avatar": {
            "type": "string",
            "example": "https://avatar.url"
          }
        }
      },
      "CreateFolderDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Resources",
            "description": "Folder name"
          },
          "description": {
            "type": "string",
            "example": "Design and dev bookmarks",
            "description": "Folder description"
          },
          "parentId": {
            "type": "string",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "description": "Parent folder ID"
          }
        },
        "required": [
          "name"
        ]
      },
      "UpdateFolderDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Resources",
            "description": "Folder name"
          },
          "description": {
            "type": "string",
            "example": "Design and dev bookmarks",
            "description": "Folder description"
          },
          "parentId": {
            "type": "string",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "description": "Parent folder ID"
          }
        }
      },
      "CreateBookmarkDto": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "example": "https://nextjs.org",
            "description": "Bookmark URL"
          },
          "title": {
            "type": "string",
            "example": "Next.js App Router",
            "description": "Bookmark title (auto-extracted if omitted)"
          },
          "description": {
            "type": "string",
            "example": "Next.js developer reference manual",
            "description": "Bookmark description"
          },
          "folderId": {
            "type": "string",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "description": "Folder ID"
          },
          "tags": {
            "example": [
              "Next.js",
              "React"
            ],
            "description": "List of tags",
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "url"
        ]
      },
      "ImportBookmarksDto": {
        "type": "object",
        "properties": {
          "htmlContent": {
            "type": "string",
            "description": "Netscape HTML bookmark file content as raw string"
          }
        },
        "required": [
          "htmlContent"
        ]
      },
      "UpdateBookmarkDto": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "example": "https://nextjs.org",
            "description": "Bookmark URL"
          },
          "title": {
            "type": "string",
            "example": "Next.js App Router",
            "description": "Bookmark title"
          },
          "description": {
            "type": "string",
            "example": "Next.js developer reference manual",
            "description": "Bookmark description"
          },
          "folderId": {
            "type": "string",
            "example": "123e4567-e89b-12d3-a456-426614174000",
            "description": "Folder ID"
          },
          "tags": {
            "example": [
              "Next.js",
              "React"
            ],
            "description": "List of tags",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "isFavorite": {
            "type": "boolean",
            "example": true,
            "description": "Is bookmarked as favorite"
          },
          "isArchived": {
            "type": "boolean",
            "example": false,
            "description": "Is bookmarked archived"
          }
        }
      },
      "CreateTransactionDto": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "example": "EXPENSE",
            "description": "Transaction type",
            "enum": [
              "EXPENSE",
              "INCOME"
            ]
          },
          "amount": {
            "type": "number",
            "example": 12.5,
            "description": "Amount of transaction"
          },
          "title": {
            "type": "string",
            "example": "Coffee",
            "description": "Title of transaction"
          },
          "description": {
            "type": "string",
            "example": "Venti Latte at Starbucks",
            "description": "Description of transaction"
          },
          "category": {
            "type": "string",
            "example": "Food",
            "description": "Category"
          },
          "date": {
            "type": "string",
            "example": "2026-07-15T00:00:00.000Z",
            "description": "Date"
          }
        },
        "required": [
          "type",
          "amount",
          "title",
          "category"
        ]
      },
      "UpdateTransactionDto": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "example": "EXPENSE",
            "description": "Transaction type",
            "enum": [
              "EXPENSE",
              "INCOME"
            ]
          },
          "amount": {
            "type": "number",
            "example": 12.5,
            "description": "Amount of transaction"
          },
          "title": {
            "type": "string",
            "example": "Coffee",
            "description": "Title of transaction"
          },
          "description": {
            "type": "string",
            "example": "Venti Latte at Starbucks",
            "description": "Description of transaction"
          },
          "category": {
            "type": "string",
            "example": "Food",
            "description": "Category"
          },
          "date": {
            "type": "string",
            "example": "2026-07-15T00:00:00.000Z",
            "description": "Date"
          }
        }
      },
      "CreateSubscriptionDto": {
