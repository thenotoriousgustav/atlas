datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String         @id @default(uuid()) @db.Uuid
  email        String         @unique
  password     String
  name         String
  avatar       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  refreshTokens RefreshToken[]
  folders       Folder[]
  bookmarks     Bookmark[]
  transactions  Transaction[]
  subscriptions Subscription[]
  vehicles      Vehicle[]
  fetchHistories FetchHistory[]
  fetchCollections FetchCollection[]
  credentials   UserCredential[]
  accounts        Account[]
  categoryGroups  CategoryGroup[]
  categories      Category[]
  budgetEntries   BudgetEntry[]
  recurringTransactions RecurringTransaction[]
  ownedShares     BudgetShare[]  @relation("OwnedShares")
  receivedShares  BudgetShare[]  @relation("ReceivedShares")
  emailSyncConfig EmailSyncConfig?

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @db.Uuid
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Folder {
  id          String     @id @default(uuid()) @db.Uuid
  name        String
  description String?
  parentId    String?    @db.Uuid
  userId      String     @db.Uuid
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Folder?    @relation("FolderToFolder", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[]   @relation("FolderToFolder")
  bookmarks Bookmark[]

  @@map("folders")
}

model Bookmark {
  id          String    @id @default(uuid()) @db.Uuid
  url         String
  title       String
  description String?
  imageUrl    String?
  isFavorite  Boolean   @default(false)
  isArchived  Boolean   @default(false)
  folderId    String?   @db.Uuid
  userId      String    @db.Uuid
  status      String    @default("OK")
  statusCode  Int?
  lastChecked DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tags   Tag[]   @relation("BookmarkTags")

  @@map("bookmarks")
}

model Tag {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookmarks Bookmark[] @relation("BookmarkTags")

  @@map("tags")
}

model Transaction {
  id                String    @id @default(uuid()) @db.Uuid
  type              String    // "EXPENSE", "INCOME", "TRANSFER"
  amount            Float
  title             String
  description       String?
  category          String?   // deprecated, keep optional for migration
  date              DateTime  @default(now())
  accountId         String    @db.Uuid
  categoryId        String?   @db.Uuid
  transferAccountId String?   @db.Uuid
  transferPairId    String?   @db.Uuid
  userId            String    @db.Uuid
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  account           Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categoryRel       Category? @relation(fields: [categoryId], references: [id])

  @@map("transactions")
}

model Subscription {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  cost         Float
  billingCycle String    // "WEEKLY", "MONTHLY", "YEARLY"
  startDate    DateTime
  status       String    @default("ACTIVE") // "ACTIVE", "PAUSED", "CANCELLED"
  userId       String    @db.Uuid
  category     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Account {
  id           String        @id @default(uuid()) @db.Uuid
  name         String        // "Cash", "BCA", "GoPay"
  type         String        // "CHECKING", "SAVINGS", "CASH", "CREDIT_CARD", "E_WALLET"
  balance      Float         @default(0)
  currency     String        @default("IDR")
  isOnBudget   Boolean       @default(true)
  sortOrder    Int           @default(0)
  userId       String        @db.Uuid
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  recurringTransactions RecurringTransaction[]

  @@map("accounts")
}

model CategoryGroup {
  id         String     @id @default(uuid()) @db.Uuid
  name       String     // "Kebutuhan Harian", "Tagihan Bulanan"
  sortOrder  Int        @default(0)
  isHidden   Boolean    @default(false)
  userId     String     @db.Uuid
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories Category[]

  @@map("category_groups")
}

model Category {
  id              String        @id @default(uuid()) @db.Uuid
  name            String        // "Makanan", "Transport"
  categoryGroupId String        @db.Uuid
  sortOrder       Int           @default(0)
  isHidden        Boolean       @default(false)
  userId          String        @db.Uuid
  targetAmount    Float?
  targetType      String?       // "MONTHLY_SPENDING", "SAVINGS_BALANCE", "MONTHLY_BUILDER"
  targetMonth     Int?
  targetYear      Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryGroup   CategoryGroup @relation(fields: [categoryGroupId], references: [id], onDelete: Cascade)
  budgetEntries   BudgetEntry[]
  transactions    Transaction[]
  recurringTransactions RecurringTransaction[]

  @@map("categories")
}

model BudgetEntry {
  id         String   @id @default(uuid()) @db.Uuid
  categoryId String   @db.Uuid
  month      Int      // 1-12
  year       Int      // 2026
  assigned   Float    @default(0)
  userId     String   @db.Uuid
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, month, year])
  @@map("budget_entries")
}

model RecurringTransaction {
  id                String    @id @default(uuid()) @db.Uuid
  title             String
  amount            Float
  type              String    // "EXPENSE", "INCOME", "TRANSFER"
  frequency         String    // "DAILY", "WEEKLY", "MONTHLY", "YEARLY"
  nextDate          DateTime  // next date this should be posted
  lastPostedAt      DateTime? // when it was last posted
  
  accountId         String    @db.Uuid
  categoryId        String?   @db.Uuid
  transferAccountId String?   @db.Uuid
  
  userId            String    @db.Uuid
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  account           Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category          Category? @relation(fields: [categoryId], references: [id])

  @@map("recurring_transactions")
}

model Vehicle {
  id            String            @id @default(uuid()) @db.Uuid
  userId        String            @db.Uuid
  brand         String
  model         String
  variant       String?
  year          Int
  plateNumber   String
  vin           String?
  engineNumber  String?
  chassisNumber String?
  purchasePrice Float?
  purchaseDate  DateTime?
  odometer      Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  maintenances Maintenance[]
  parts        Part[]
  fuelLogs     FuelLog[]
  expenses     Expense[]
  reminders    Reminder[]
  documents    VehicleDocument[]

  @@map("vehicles")
}

model Maintenance {
  id         String            @id @default(uuid()) @db.Uuid
  vehicleId  String            @db.Uuid
  date       DateTime          @default(now())
  odometer   Int
  workshop   String?
  notes      String?
  totalCost  Float
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  deletedAt  DateTime?

  vehicle   Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  items     MaintenanceItem[]
  parts     Part[]

  @@map("maintenances")
}

model MaintenanceItem {
  id            String      @id @default(uuid()) @db.Uuid
  maintenanceId String      @db.Uuid
  type          String
  cost          Float
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  maintenance   Maintenance @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)

  @@map("maintenance_items")
}

model Part {
  id               String       @id @default(uuid()) @db.Uuid
  vehicleId        String       @db.Uuid
  maintenanceId    String?      @db.Uuid
  name             String
  brand            String?
  installedAt      DateTime?
  installedMileage Int?
  expectedLife     Int?         // expected mileage lifetime
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  vehicle     Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  maintenance Maintenance? @relation(fields: [maintenanceId], references: [id], onDelete: SetNull)

  @@map("parts")
}

model FuelLog {
  id        String    @id @default(uuid()) @db.Uuid
  vehicleId String    @db.Uuid
  liters    Float
  price     Float     // price per liter
  odometer  Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("fuel_logs")
}

model Expense {
  id        String    @id @default(uuid()) @db.Uuid
  vehicleId String    @db.Uuid
  category  String
  amount    Float
  date      DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

model Reminder {
  id         String    @id @default(uuid()) @db.Uuid
  vehicleId  String    @db.Uuid
  type       String
  dueDate    DateTime?
  dueMileage Int?
  status     String    @default("ACTIVE") // "ACTIVE", "COMPLETED", "OVERDUE"
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("reminders")
}

model VehicleDocument {
  id             String    @id @default(uuid()) @db.Uuid
  vehicleId      String    @db.Uuid
  documentType   String    // "STNK", "Insurance", "Warranty", "Other"
  documentNumber String
  expirationDate DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  vehicle        Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("vehicle_documents")
}

model FetchHistory {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @db.Uuid
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  url          String
  title        String
  author       String?
  platform     String
  mediaType    String           // "VIDEO", "AUDIO", "IMAGE"
  fileSize     Float?           // in bytes
  resolution   String?
  thumbnail    String?
  notes        String?
  isFavorite   Boolean          @default(false)
  collectionId String?          @db.Uuid
  collection   FetchCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?

  @@map("fetch_histories")
}

model FetchCollection {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @db.Uuid
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  histories FetchHistory[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?

  @@map("fetch_collections")
}

model UserCredential {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String   @unique
  publicKey    Bytes
  counter      BigInt
  transports   String[]
  createdAt    DateTime @default(now())

  @@map("user_credentials")
}

model BudgetShare {
  id           String   @id @default(uuid()) @db.Uuid
  ownerId      String   @db.Uuid
  grantedToId  String   @db.Uuid
  createdAt    DateTime @default(now())

  owner        User     @relation("OwnedShares", fields: [ownerId], references: [id], onDelete: Cascade)
  grantedTo    User     @relation("ReceivedShares", fields: [grantedToId], references: [id], onDelete: Cascade)

  @@unique([ownerId, grantedToId])
  @@map("budget_shares")
}

model EmailSyncConfig {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @unique @db.Uuid
  imapHost   String
  imapPort   Int       @default(993)
  username   String
  password   String
  isActive   Boolean   @default(false)
  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_sync_configs")
}
